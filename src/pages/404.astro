---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Pagină negăsită (404) | FrigidereIeftine.ro" description="Pagina căutată nu există sau a fost mutată." noindex={true}>
  <Navigation />
  <section class="section fr-sec"><div class="container" style="text-align:center;max-width:640px;margin:0 auto">
    <span class="section-label">Eroare 404</span>
    <h1 class="section-title">Pagina nu există</h1>
    <p class="section-intro" style="margin:0 auto 1.6rem">Pagina căutată nu mai există sau adresa e greșită. Poate frigiderul căutat nu mai este disponibil.</p>
    <p><a href="/oferte/" class="pg">Vezi toate frigiderele →</a> &nbsp; <a href="/" class="pg">Acasă</a></p>
  </div></section>
  <Footer />
</Layout>
