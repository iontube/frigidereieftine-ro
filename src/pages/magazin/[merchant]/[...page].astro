---
import Layout from '../../../layouts/Layout.astro';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../components/Footer.astro';
import FridgeCard from '../../../components/FridgeCard.astro';
import products from '../../../data/frigidere.json';
export function getStaticPaths() {
  const PAGE = 48; const by = {};
  for (const p of products) for (const o of p.offers) { (by[o.merchantSlug] ||= { name:o.merchantName, items:[] }); if (!by[o.merchantSlug].items.includes(p)) by[o.merchantSlug].items.push(p); }
  const paths = [];
  for (const [mslug,{name,items}] of Object.entries(by)) { items.sort((a,b)=>a.price-b.price); const last=Math.ceil(items.length/PAGE);
    for (let pg=1; pg<=last; pg++) paths.push({ params:{ merchant:mslug, page: pg===1?undefined:String(pg) }, props:{ mName:name, mslug, items:items.slice((pg-1)*PAGE,pg*PAGE), currentPage:pg, lastPage:last, total:items.length } }); }
  return paths;
}
const { mName, mslug, items, currentPage, lastPage, total } = Astro.props;
const base = `/magazin/${mslug}/`;
const pageMod = items.reduce((m,p)=>(p.modified&&p.modified>m?p.modified:m),'2026-04-01');
const title = currentPage===1?`Frigidere la ${mName}: ${total} oferte sub 1500 lei | FrigidereIeftine.ro`:`Frigidere la ${mName} – pagina ${currentPage} | FrigidereIeftine.ro`;
const desc = `Toate frigiderele ieftine disponibile la ${mName}: ${total} de modele sub 1500 lei, cu prețuri actualizate.`;
---
<Layout title={title} description={desc} modified={pageMod}>
  <Navigation />
  <section class="section fr-sec"><div class="container">
    <nav class="crumb"><a href="/">Acasă</a> › <a href="/oferte/">Oferte frigidere</a> › <span>{mName}</span></nav>
    <span class="section-label">Magazin</span>
    <h1 class="section-title">Frigidere la {mName}</h1>
    <p class="section-intro"><strong>{total}</strong> de frigidere disponibile la {mName}, cu prețuri actualizate periodic.{lastPage > 1?` Pagina ${currentPage} din ${lastPage}.`:''}</p>
    <div class="products-grid">{items.map((p)=><FridgeCard p={p} />)}</div>
    {lastPage > 1 && (<nav class="pager" aria-label="Paginare">
      {currentPage > 1 ? <a class="pg" href={currentPage===2?base:`${base}${currentPage-1}/`}>← Anterioarele</a> : <span class="pg pg--off">← Anterioarele</span>}
      <span class="pg-now">Pagina {currentPage} / {lastPage}</span>
      {currentPage < lastPage ? <a class="pg" href={`${base}${currentPage+1}/`}>Următoarele →</a> : <span class="pg pg--off">Următoarele →</span>}</nav>)}
    <p class="po-back"><a href="/oferte/">← Vezi toate ofertele</a></p>
  </div></section>
  <Footer />
</Layout>
