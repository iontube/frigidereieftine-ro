---
const links = [
  { href: '#produse', label: 'Frigidere' },
  { href: '#review-uri', label: 'Analize' },
  { href: '#ghid', label: 'Ce trebuie sa stii' },
  { href: '#comparatie', label: 'Comparatie' },
  { href: '#categorii', label: 'Pe categorii' },
  { href: '#faq', label: 'Intrebari' },
];
---
<nav class="nav" aria-label="Navigare principala">
  <div class="container nav-inner">
    <a href="/" class="nav-brand"><img src="/assets/images/logo-frigidereieftine.webp" alt="frigidereieftine.ro" width="330" height="71"></a>
    <div class="nav-links nav-links--desktop">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </div>
    <button class="nav-toggle" aria-label="Deschide meniul" aria-expanded="false" data-menu-toggle>
      <svg class="nav-toggle-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
        <rect x="0" y="0" width="9" height="9" rx="2.5"/>
        <rect x="11" y="0" width="9" height="9" rx="2.5"/>
        <rect x="0" y="11" width="9" height="9" rx="2.5"/>
        <rect x="11" y="11" width="9" height="9" rx="2.5"/>
      </svg>
    </button>
  </div>
</nav>

<div class="mobile-menu" data-mobile-menu>
  <div class="mobile-menu-overlay" data-menu-close></div>
  <div class="mobile-menu-panel">
    <div class="mobile-menu-header">
      <span class="nav-brand"><img src="/assets/images/logo-frigidereieftine.webp" alt="frigidereieftine.ro" width="330" height="71"></span>
      <button class="mobile-menu-close" aria-label="Inchide meniul" data-menu-close>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="mobile-menu-links">
      {links.map(l => <a href={l.href} data-menu-close>{l.label}</a>)}
    </div>
    <div class="mobile-menu-cta">
      <a href="#produse" class="btn btn-primary" data-menu-close>Arata-mi frigiderele</a>
    </div>
  </div>
</div>

<style>
  .nav-links--desktop{display:flex;gap:.25rem;flex-wrap:wrap}
  .nav-toggle{display:none;align-items:center;justify-content:center;width:40px;height:40px;padding:0;background:var(--c-surface);border:1px solid var(--c-border);cursor:pointer;border-radius:var(--radius-sm);transition:all .2s var(--transition);color:var(--c-text)}
  .nav-toggle:hover{background:var(--c-primary-light);border-color:var(--c-primary);color:var(--c-primary)}
  .nav-toggle-icon{transition:transform .3s var(--transition)}
  .nav-toggle[aria-expanded="true"] .nav-toggle-icon{transform:rotate(90deg)}

  .mobile-menu{position:fixed;inset:0;z-index:200;pointer-events:none;visibility:hidden}
  .mobile-menu.is-open{pointer-events:auto;visibility:visible}

  .mobile-menu-overlay{position:absolute;inset:0;background:rgba(28,25,23,.4);opacity:0;transition:opacity .3s var(--transition);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
  .mobile-menu.is-open .mobile-menu-overlay{opacity:1}

  .mobile-menu-panel{position:absolute;top:0;right:0;bottom:0;width:min(320px,85vw);background:var(--c-bg);box-shadow:var(--shadow-lg);transform:translateX(100%);transition:transform .35s var(--transition);display:flex;flex-direction:column;overflow-y:auto}
  .mobile-menu.is-open .mobile-menu-panel{transform:translateX(0)}

  .mobile-menu-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--c-border)}
  .mobile-menu-header .nav-brand{font-size:1rem}
  .mobile-menu-close{display:flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;border:none;background:var(--c-surface);color:var(--c-text);cursor:pointer;transition:all .2s}
  .mobile-menu-close:hover{background:var(--c-border)}

  .mobile-menu-links{display:flex;flex-direction:column;padding:1rem .75rem;gap:.25rem;flex:1}
  .mobile-menu-links a{display:flex;align-items:center;padding:.9rem 1rem;border-radius:var(--radius-sm);font-size:1rem;font-weight:600;color:var(--c-text);transition:all .15s}
  .mobile-menu-links a:hover{background:var(--c-primary-light);color:var(--c-primary)}

  .mobile-menu-cta{padding:1rem 1.5rem 1.5rem;border-top:1px solid var(--c-border)}
  .mobile-menu-cta .btn{width:100%;justify-content:center}

  @media(max-width:768px){
    .nav-links--desktop{display:none}
    .nav-toggle{display:flex}
  }
  @media(min-width:769px){
    .mobile-menu{display:none}
  }
</style>

<script>
  const toggle = document.querySelector('[data-menu-toggle]') as HTMLButtonElement;
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement;
  const closers = document.querySelectorAll('[data-menu-close]');

  function openMenu() {
    menu.classList.add('is-open');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.remove('is-open');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  closers.forEach(el => el.addEventListener('click', closeMenu));
</script>
