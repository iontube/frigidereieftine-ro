            <svg class="video-play" viewBox="0 0 68 48" width="68" height="48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .guide-img-block{margin:2.5rem -1rem;border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-md)}
  .guide-img-block img{width:100%;height:auto;display:block}
  .guide-video{margin:3rem 0 0}
  .guide-content-heading{border-left:none;padding-left:0;text-align:center;margin-bottom:1.25rem;font-size:1.2rem;font-weight:700;color:var(--c-text)}
  .video-thumb{display:block;width:100%;border:none;background:none;cursor:pointer;padding:0;position:relative}
  .video-thumb img{width:100%;height:auto;display:block;border-radius:var(--radius)}
  .video-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);filter:drop-shadow(0 2px 8px rgba(0,0,0,.3));transition:transform .2s}
  .video-thumb:hover .video-play{transform:translate(-50%,-50%) scale(1.1)}
  .video-wrap{position:relative;overflow:hidden;border-radius:var(--radius-lg);box-shadow:var(--shadow-md)}
  @media(max-width:768px){
    .guide-img-block{margin:1.5rem 0;border-radius:var(--radius-sm);box-shadow:none}
    .guide-video{margin:2rem 0 0}
    .guide-content-heading{font-size:1rem}
    .video-wrap{border-radius:0;box-shadow:none}
  }
</style>

<script>
  const wrap = document.getElementById('ytPlayer');
  if (wrap) {
    wrap.addEventListener('click', () => {
      const id = wrap.dataset.id;
      wrap.style.paddingBottom = '56.25%';
      wrap.style.height = '0';
      wrap.innerHTML = `<iframe src="https://www.youtube.com/embed/${id}?autoplay=1" title="Video" style="position:absolute;top:0;left:0;width:100%;height:100%;border:0" allow="accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture" allowfullscreen></iframe>`;
    });
  }
</script>
