---
const year = new Date().getFullYear();

const legalLinks = [
  { href: '/politica-confidentialitate/', label: 'Politica de confidentialitate' },
  { href: '/politica-cookies/', label: 'Politica cookies' },
  { href: '/termeni-si-conditii/', label: 'Termeni si conditii' },
  { href: '/disclaimer-afiliere/', label: 'Disclaimer afiliere' },
  { href: '/contact/', label: 'Contact' },
];
---
<div class="footer">
  <div class="container">
    <nav class="footer-legal" aria-label="Pagini legale">
      <a href="/despre-noi/">Despre noi</a>
      {legalLinks.map(l => <a href={l.href} rel="nofollow">{l.label}</a>)}
    </nav>
    <p class="footer-updated">Continut actualizat: <time datetime="2026-03">martie 2026</time></p>
    <p class="footer-copy">&copy; {year} frigidereieftine.ro</p>
  </div>
</div>

<style>
  .footer-legal{display:flex;flex-wrap:wrap;justify-content:center;gap:.5rem 1.25rem;margin-bottom:1rem}
  .footer-legal a{font-size:.8rem;color:var(--c-text-light);transition:color .2s}
  .footer-legal a:hover{color:var(--c-primary)}
  .footer-updated{font-size:.78rem;margin-bottom:.5rem}
  .footer-copy{font-size:.8rem;margin:0}
</style>
