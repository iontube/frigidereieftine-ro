---
---
<section class="section">
  <div class="container">
    <div class="rating-box" id="ratingBox">
      <p class="rating-title">Recenziile noastre ti-au fost utile?</p>
      <p class="rating-sub">Acorda-ne o nota si ajuta-ne sa ne imbunatatim.</p>
      <div class="rating-stars" id="ratingStars">
        {[1,2,3,4,5].map(i => (
          <button class="rating-star" data-star={i} aria-label={`${i} stele`}>
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke-linejoin="round"/>
            </svg>
          </button>
        ))}
      </div>
      <div class="rating-result" id="ratingResult">
        <span class="rating-avg" id="ratingAvg">4.7</span><span class="rating-of">/5 din </span><span class="rating-count" id="ratingCount">237</span><span class="rating-of"> voturi</span>
      </div>
      <div class="rating-thanks" id="ratingThanks">
        Multumim pentru vot!
      </div>
    </div>
  </div>
</section>

<style>
  .rating-box{max-width:480px;margin:0 auto;text-align:center;background:linear-gradient(135deg,#f0fdfa,#fff);border:1px solid var(--c-border);border-radius:var(--radius);padding:2.5rem 2rem}
  .rating-title{font-size:1.2rem;margin-bottom:.35rem;font-weight:800;color:var(--c-text)}
  .rating-sub{color:var(--c-text-light);font-size:.9rem;margin-bottom:1.5rem}
  .rating-stars{display:flex;justify-content:center;gap:.35rem;margin-bottom:1.25rem}
  .rating-star{background:none;border:none;cursor:pointer;color:var(--c-border);padding:.15rem;transition:all .15s;border-radius:4px}
  .rating-star:hover{transform:scale(1.15)}
  .rating-star.active svg{fill:var(--c-primary);stroke:var(--c-primary);color:var(--c-primary)}
  .rating-star.hover svg{fill:var(--c-primary-light);stroke:var(--c-primary);color:var(--c-primary)}
  .rating-result{font-size:.95rem;color:var(--c-text-mid)}
  .rating-avg{font-weight:800;font-size:1.1rem;color:var(--c-primary)}
  .rating-count{font-weight:700;color:var(--c-text)}
  .rating-of{color:var(--c-text-light)}
  .rating-thanks{display:none;color:var(--c-primary);font-weight:600;font-size:.95rem;margin-top:.75rem}
  .rating-box.voted .rating-thanks{display:block}
  .rating-box.voted .rating-star{pointer-events:none}
  @media(max-width:768px){
    .rating-box{padding:1.75rem 1.25rem}
    .rating-title{font-size:1.05rem}
    .rating-star svg{width:30px;height:30px}
  }
</style>

<script>
  const box = document.getElementById('ratingBox');
  const stars = document.querySelectorAll('.rating-star');
  const avgEl = document.getElementById('ratingAvg');
  const countEl = document.getElementById('ratingCount');
  const hasVoted = localStorage.getItem('site-rated');

  function renderStars(n) {
    stars.forEach((s, i) => s.classList.toggle('active', i < n));
  }

  if (hasVoted) {
    renderStars(parseInt(hasVoted));
    box.classList.add('voted');
  }

  stars.forEach((star, i) => {
    star.addEventListener('mouseenter', () => {
      if (hasVoted) return;
      stars.forEach((s, j) => s.classList.toggle('hover', j <= i));
    });
    star.addEventListener('mouseleave', () => {
      stars.forEach(s => s.classList.remove('hover'));
    });
    star.addEventListener('click', async () => {
      if (localStorage.getItem('site-rated')) return;
      const vote = i + 1;
      localStorage.setItem('site-rated', String(vote));
      renderStars(vote);
      stars.forEach(s => s.classList.remove('hover'));
      box.classList.add('voted');

      try {
        const ep = ['','api','rating'].join('/');
        const res = await fetch(ep, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ vote }),
        });
        if (res.ok) {
          const data = await res.json();
          avgEl.textContent = data.avg;
          countEl.textContent = String(data.count);
        }
      } catch (e) {}
    });
  });
</script>
